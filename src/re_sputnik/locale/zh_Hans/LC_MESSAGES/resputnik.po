#: src/re_sputnik/ui/antidpi_screen.py:337
#: src/re_sputnik/ui/antidpi_screen.py:449
#: src/re_sputnik/ui/antidpi_screen.py:467
msgid "— выбрать —"
msgstr "— 请选择 —"

#: src/re_sputnik/ui/antidpi_screen.py:135
msgid "Стратегия (аргументы ciadpi):"
msgstr "策略（ciadpi 参数）："

#: src/re_sputnik/ui/antidpi_screen.py:142
#: src/re_sputnik/ui/antidpi_screen.py:353
