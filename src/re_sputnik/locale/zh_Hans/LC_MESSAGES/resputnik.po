#: src/re_sputnik/ui/firstrun_screen.py:254
#: src/re_sputnik/ui/internet_screen.py:230
msgid "Применить"
msgstr "应用"

#: src/re_sputnik/ui/advanced_screen.py:516
#: src/re_sputnik/ui/wifi_ap_screen.py:157
msgid "Введите имя сети."
msgstr "请输入网络名称。"

#: src/re_sputnik/ui/advanced_screen.py:519
msgid "Пароль не короче 8 символов."
msgstr "密码长度不能少于 8 个字符。"

#: src/re_sputnik/ui/advanced_screen.py:522
#: src/re_sputnik/ui/wifi_ap_screen.py:164
msgid "Настраиваю Wi-Fi…"
msgstr "正在配置 Wi-Fi…"

#: src/re_sputnik/ui/advanced_screen.py:528
msgid "Готово — сеть обновлена."
msgstr "完成——网络已更新。"

#: src/re_sputnik/ui/advanced_screen.py:531
msgid ""
"Применено, но диапазон не поднялся — возможно, канал не разрешён в этом "
"регионе. Попробуйте другой канал."
msgstr "已应用，但该频段未能启动——该信道可能在本地区不被允许。请尝试其他信道。"

#: src/re_sputnik/ui/advanced_screen.py:547
msgid "Сеть LAN и DHCP"
msgstr "LAN 网络和 DHCP"

#: src/re_sputnik/ui/advanced_screen.py:551
msgid ""
"На сборке OpenWrt SNAPSHOT формат сетевых настроек может отличаться, "
"поэтому менять адрес роутера и DHCP отсюда небезопасно. Настройте сеть "
"самостоятельно — через веб-интерфейс роутера (браузер) или консоль."
msgstr ""
"在 OpenWrt SNAPSHOT 构建上，网络设置的格式可能有所不同，因此从这里更改路由器地址和 DHCP "
"并不安全。请通过路由器的网页界面（浏览器）或控制台自行配置网络。"

#: src/re_sputnik/ui/advanced_screen.py:572
msgid "IP-адрес роутера с маской (CIDR)"
msgstr "带子网掩码的路由器 IP 地址（CIDR）"

#: src/re_sputnik/ui/advanced_screen.py:573
msgid ""
"Адрес роутера вместе с размером подсети через «/», например "
"192.168.1.1/24. По этому адресу открываются настройки; его же вы вводите "
"в приложении."
msgstr "路由器地址加上以“/”分隔的子网大小，例如 192.168.1.1/24。设置页面在此地址打开；您在应用中输入的也是这个地址。"

#: src/re_sputnik/ui/advanced_screen.py:580
msgid "IP-адрес роутера"
msgstr "路由器 IP 地址"

#: src/re_sputnik/ui/advanced_screen.py:581
msgid ""
"Адрес, по которому открываются настройки роутера; его же вы вводите в "
"приложении. Обычно 192.168.1.1."
msgstr "打开路由器设置的地址；您在应用中输入的也是这个地址。通常为 192.168.1.1。"

#: src/re_sputnik/ui/advanced_screen.py:586
msgid "Маска подсети"
msgstr "子网掩码"

#: src/re_sputnik/ui/advanced_screen.py:587
msgid "Размер локальной сети. Если не уверены — оставьте 255.255.255.0."
msgstr "本地网络的大小。如果不确定，请保留 255.255.255.0。"

#: src/re_sputnik/ui/advanced_screen.py:591
msgid "DHCP: начало диапазона"
msgstr "DHCP：范围起始地址"

#: src/re_sputnik/ui/advanced_screen.py:592
msgid ""
"С какого адреса роутер начинает раздавать IP. 100 означает 192.168.1.100."
" Адреса до него (1–99) остаются свободными — их удобно отдавать под "
"постоянные IP устройств."
msgstr "路由器从哪个地址开始分配 IP。100 表示 192.168.1.100。之前的地址（1–99）保持空闲——便于分配给设备的固定 IP。"

#: src/re_sputnik/ui/advanced_screen.py:594
msgid "DHCP: сколько адресов раздавать"
msgstr "DHCP：分配多少个地址"

#: src/re_sputnik/ui/advanced_screen.py:595
msgid ""
"Максимум устройств, которым роутер выдаст адрес автоматически (размер "
"диапазона)."
msgstr "路由器自动分配地址的最大设备数（范围大小）。"

#: src/re_sputnik/ui/advanced_screen.py:605
msgid "Время аренды адреса (ЧЧ:ММ)"
msgstr "地址租约时间（时:分）"

#: src/re_sputnik/ui/advanced_screen.py:617
msgid ""
"Через какое время устройство заново запрашивает свой адрес. Например "
"12:00 — каждые 12 часов. Слишком малое значение нагружает сеть."
msgstr "设备重新请求其地址前的时间间隔。例如 12:00 表示每 12 小时一次。值过小会增加网络负担。"

#: src/re_sputnik/ui/advanced_screen.py:627
msgid "Подтвердить"
msgstr "确认"

#: src/re_sputnik/ui/advanced_screen.py:628
msgid ""
"Изменение адреса роутера, маски или DHCP отключит ВСЕ устройства, включая"
" это. Может потребоваться полный сброс роутера. Делайте только при "
"крайней необходимости — приложение отключится и переподключится по новому"
" адресу."
msgstr "更改路由器地址、掩码或 DHCP 将断开所有设备的连接，包括此设备。可能需要完全重置路由器。仅在确有必要时执行——应用将断开连接并以新地址重新连接。"

#: src/re_sputnik/ui/advanced_screen.py:664
msgid "Неверный адрес. Укажите IP с маской через «/», например 192.168.1.1/24."
msgstr "地址无效。请输入带“/”子网掩码的 IP，例如 192.168.1.1/24。"

#: src/re_sputnik/ui/advanced_screen.py:674
msgid "Неверный адрес."
msgstr "地址无效。"

#: src/re_sputnik/ui/advanced_screen.py:686
#, python-brace-format
msgid ""
"Применяется. Роутер переедет на {0} — приложение отключится, "
"переподключитесь по новому адресу."
msgstr "正在应用。路由器将迁移到 {0}——应用将断开连接，请使用新地址重新连接。"

#: src/re_sputnik/ui/advanced_screen.py:699
msgid "Постоянный IP-адрес для устройства"
msgstr "设备的固定 IP 地址"

#: src/re_sputnik/ui/advanced_screen.py:700
msgid ""
"Закрепите за устройством его текущий адрес — роутер всегда будет выдавать"
" ему один и тот же IP."
msgstr "将设备的当前地址固定下来——路由器将始终分配给它同一个 IP。"

#: src/re_sputnik/ui/advanced_screen.py:716
msgid "Закрепить адрес"
msgstr "固定地址"

#: src/re_sputnik/ui/advanced_screen.py:720
msgid "Все известные устройства уже закреплены или нет устройств с MAC."
msgstr "所有已知设备都已固定，或没有带 MAC 的设备。"

#: src/re_sputnik/ui/advanced_screen.py:727
msgid "Закреплённые:"
msgstr "已固定："

#: src/re_sputnik/ui/advanced_screen.py:735
msgid "Убрать"
msgstr "移除"

#: src/re_sputnik/ui/advanced_screen.py:746
msgid "Закрепляю адрес…"
msgstr "正在固定地址…"

#: src/re_sputnik/ui/advanced_screen.py:764
msgid "UPnP / переадресация портов"
msgstr "UPnP / 端口转发"

#: src/re_sputnik/ui/advanced_screen.py:765
msgid ""
"Позволяет программам и играм самим открывать нужные порты на роутере "
"(онлайн-игры, торренты, видеозвонки). Удобно, но снижает контроль над "
"тем, какие порты открыты."
msgstr "允许程序和游戏自行在路由器上打开所需端口（在线游戏、torrent、视频通话）。方便，但会降低对开放端口的控制。"

#: src/re_sputnik/ui/advanced_screen.py:776
msgid "Служба включена и работает"
msgstr "服务已启用并运行中"

#: src/re_sputnik/ui/advanced_screen.py:777
msgid "Включена, но не запущена"
msgstr "已启用，但未运行"

#: src/re_sputnik/ui/advanced_screen.py:777
msgid "Отключена"
msgstr "已禁用"

#: src/re_sputnik/ui/advanced_screen.py:781
msgid "Включить UPnP"
msgstr "启用 UPnP"

#: src/re_sputnik/ui/advanced_screen.py:792
msgid "Активные переадресации:"
msgstr "活动的端口转发："

#: src/re_sputnik/ui/advanced_screen.py:802
msgid "нет активных переадресаций"
msgstr "没有活动的端口转发"

#: src/re_sputnik/ui/advanced_screen.py:819
msgid "SQM — сглаживание буфера (bufferbloat)"
msgstr "SQM — 缓冲平滑（缓冲膨胀）"

#: src/re_sputnik/ui/advanced_screen.py:820
msgid ""
"Убирает «залипания» интернета, когда кто-то качает или грузит канал "
"(видеозвонки, игры перестают тормозить). Ограничивает скорость чуть ниже "
"реальной, чтобы роутер управлял очередью пакетов. Требователен к "
"производительности роутера: на тарифах с высокой скоростью (500+ Мбит/с) "
"может занижать скорость из-за нехватки мощности."
msgstr ""
"当有人下载或占用带宽时，消除网络“卡顿”（视频通话和游戏不再卡顿）。会将速度限制在实际速度之下，以便路由器管理数据包队列。对路由器性能要求较高：在高速套餐（500+"
" Mbps）上，可能因性能不足而降低速度。"

#: src/re_sputnik/ui/advanced_screen.py:844
msgid "WAN-интерфейс (что ограничиваем)"
msgstr "WAN 接口（要限速的对象）"

#: src/re_sputnik/ui/advanced_screen.py:845
msgid ""
"Устройство, через которое роутер выходит в интернет. Обычно определяется "
"автоматически."
msgstr "路由器接入互联网所使用的接口。通常自动检测。"

#: src/re_sputnik/ui/advanced_screen.py:852
msgid "Скорость приёма, кбит/с"
msgstr "下载速度，kbit/s"

#: src/re_sputnik/ui/advanced_screen.py:853
msgid ""
"Поставьте ~90–95% от тарифной скорости загрузки, либо на 1–2 Мбит/с "
"меньше реально измеренной. Например, при тарифе 100 Мбит/с — около "
"90000–95000."
msgstr "设置为套餐下载速度的约 90–95%，或比实测值低 1–2 Mbps。例如 100 Mbps 套餐——大约 90000–95000。"

#: src/re_sputnik/ui/advanced_screen.py:859
msgid "Скорость отдачи, кбит/с"
msgstr "上传速度，kbit/s"

#: src/re_sputnik/ui/advanced_screen.py:860
msgid ""
"Так же: ~90–95% от тарифной скорости отдачи (upload) или на 1–2 Мбит/с "
"меньше измеренной."
msgstr "同样：约为套餐上传速度的 90–95%，或比实测值低 1–2 Mbps。"

#: src/re_sputnik/ui/advanced_screen.py:866
msgid "Дисциплина очереди"
msgstr "队列调度算法"

#: src/re_sputnik/ui/advanced_screen.py:867
msgid ""
"cake — современная, рекомендуется (сама управляет приоритетами). fq_codel"
" — проще и легче, для слабых роутеров."
msgstr "cake——现代算法，推荐使用（自动管理优先级）。fq_codel——更简单更轻量，适合性能较弱的路由器。"

#: src/re_sputnik/ui/advanced_screen.py:877
msgid "Шаблон настройки очереди"
msgstr "队列设置模板"

#: src/re_sputnik/ui/advanced_screen.py:878
msgid ""
"Простой подходит почти всем. «С приоритизацией» отдаёт приоритет звонкам "
"и играм перед загрузками, но чуть тяжелее."
msgstr "简单模式适合几乎所有人。“带优先级”会让通话和游戏优先于下载，但稍微更耗资源。"

#: src/re_sputnik/ui/advanced_screen.py:886
msgid "Накладные расходы на пакет, байт"
msgstr "每包开销，字节"

#: src/re_sputnik/ui/advanced_screen.py:887
msgid ""
"Запас на служебные данные канала. 44 подходит для большинства подключений"
" (Ethernet/оптика/кабель). Для DSL может быть иначе — если не уверены, "
"оставьте 44."
msgstr "为链路开销预留的余量。44 适合大多数连接（以太网/光纤/有线）。DSL 可能不同——如果不确定，保留 44。"

#: src/re_sputnik/ui/advanced_screen.py:894
msgid "Включить SQM"
msgstr "启用 SQM"

#: src/re_sputnik/ui/advanced_screen.py:900
#: src/re_sputnik/ui/advanced_screen.py:934
#: src/re_sputnik/ui/advanced_screen.py:942
msgid "Измерить"
msgstr "测速"

#: src/re_sputnik/ui/advanced_screen.py:926
msgid "Измеряю…"
msgstr "正在测速…"

#: src/re_sputnik/ui/advanced_screen.py:928
msgid ""
"Измеряю скорость загрузки (несколько секунд, скачается часть тестового "
"файла)…"
msgstr "正在测量下载速度（几秒钟，会下载部分测试文件）…"

#: src/re_sputnik/ui/advanced_screen.py:938
#, python-brace-format
msgid ""
"Измерено: приём ≈ {0} кбит/с (−2% к замеру). Отдачу прикинул как {1} "
"кбит/с (половина приёма) — уточните под свой тариф и нажмите «Применить»."
msgstr "测得：下载 ≈ {0} kbit/s（比测量值低 2%）。上传估算为 {1} kbit/s（下载的一半）——请根据您的套餐调整，然后点击“应用”。"

#: src/re_sputnik/ui/advanced_screen.py:962
msgid "Настраиваю очередь…"
msgstr "正在配置队列…"

#: src/re_sputnik/ui/advanced_screen.py:967
msgid "Готово — настройки SQM применены."
msgstr "完成——SQM 设置已应用。"

#: src/re_sputnik/ui/advanced_screen.py:981
msgid "Маршрутизация прокси"
msgstr "代理路由"

#: src/re_sputnik/ui/advanced_screen.py:994
msgid "DNS для российских сайтов (напрямую)"
msgstr "俄罗斯网站的 DNS（直连）"

#: src/re_sputnik/ui/advanced_screen.py:995
msgid "DNS для китайских сайтов (напрямую)"
msgstr "中国网站的 DNS（直连）"

#: src/re_sputnik/ui/advanced_screen.py:996
msgid "DNS для иранских сайтов (напрямую)"
msgstr "伊朗网站的 DNS（直连）"

#: src/re_sputnik/ui/advanced_screen.py:997
msgid "Региональный DNS"
msgstr "区域 DNS"

#: src/re_sputnik/ui/advanced_screen.py:1011
msgid "Как основной узел"
msgstr "与主节点相同"

#: src/re_sputnik/ui/advanced_screen.py:1011
msgid "Отдельный URLTest"
msgstr "独立 URLTest"

#: src/re_sputnik/ui/advanced_screen.py:1017
msgid "Отдельный сервер для UDP (звонки, игры)"
msgstr "UDP 专用服务器（通话、游戏）"

#: src/re_sputnik/ui/advanced_screen.py:1020
msgid ""
"По умолчанию UDP идёт через основной узел. Можно выделить отдельный "
"сервер — иногда стабильнее для голоса и игр."
msgstr "默认情况下，UDP 通过主节点传输。可以指定专用服务器——有时对语音和游戏更稳定。"

#: src/re_sputnik/ui/advanced_screen.py:1049
msgid "Готово — настройки применены."
msgstr "完成 — 设置已应用。"

#: src/re_sputnik/ui/advanced_screen.py:1057
msgid "Сброс к заводским настройкам"
msgstr "恢复出厂设置"

#: src/re_sputnik/ui/advanced_screen.py:1058
msgid ""
"Полностью стирает все настройки роутера и возвращает его к состоянию «из "
"коробки» (обычно адрес 192.168.1.1, без пароля). HomeProxy, ключи, Wi-Fi "
"— всё будет удалено."
msgstr ""
"完全清除路由器的所有设置，并将其恢复到“开箱”状态（通常地址为 192.168.1.1，无密码）。HomeProxy、密钥、Wi-"
"Fi——一切都将被删除。"

#: src/re_sputnik/ui/advanced_screen.py:1067
msgid "Сбросить устройство"
msgstr "重置设备"

#: src/re_sputnik/ui/advanced_screen.py:1067
msgid "Подтвердить сброс"
msgstr "确认重置"

#: src/re_sputnik/ui/advanced_screen.py:1068
msgid ""
"Все настройки будут безвозвратно удалены, роутер перезагрузится в "
"заводском состоянии. Приложение потеряет связь. Убедитесь, что у вас есть"
" резервная копия."
msgstr "所有设置将被永久删除，路由器将以出厂状态重启。应用将失去连接。请确保您已有备份。"

#: src/re_sputnik/ui/advanced_screen.py:1076
msgid ""
"Сброс запущен. Роутер перезагрузится в заводском состоянии — подключитесь"
" заново как к новому устройству."
msgstr "重置已开始。路由器将以出厂状态重启——请将其作为新设备重新连接。"

#: src/re_sputnik/ui/advanced_screen.py:1089
#: src/re_sputnik/ui/connect_screen.py:299
msgid "Удалить данные приложения (не роутера)"
msgstr "删除应用数据（不是路由器）"

#: src/re_sputnik/ui/advanced_screen.py:1090
#: src/re_sputnik/ui/connect_screen.py:301
msgid ""
"Стирает с ЭТОГО компьютера все данные Re:Sputnik: SSH-ключ приложения, "
"сохранённые пароли роутеров, привязки host-key и список роутеров. Сам "
"роутер и его настройки не трогаются. Используйте, чтобы убрать за собой "
"на чужом или общем компьютере."
msgstr ""
"从本台计算机抹除所有 Re:Sputnik 数据：应用的 SSH "
"密钥、已保存的路由器密码、主机密钥指纹以及路由器列表。路由器本身及其设置不受影响。可用于在他人或公用电脑上清理你的痕迹。"

#: src/re_sputnik/ui/advanced_screen.py:1100
#: src/re_sputnik/ui/connect_screen.py:266
#: src/re_sputnik/ui/connect_screen.py:289
#: src/re_sputnik/ui/connect_screen.py:311
msgid "Удалить данные приложения"
msgstr "删除应用数据"

#: src/re_sputnik/ui/advanced_screen.py:1101
#: src/re_sputnik/ui/connect_screen.py:312
msgid "Да, удалить данные"
msgstr "是的，删除数据"

#: src/re_sputnik/ui/advanced_screen.py:1102
#: src/re_sputnik/ui/connect_screen.py:313
msgid ""
"После удаления для следующего входа понадобится пароль root роутера. Он у"
" вас есть — его показывали при настройке, и его можно посмотреть на "
"устройстве в разделе «Безопасность». ВАЖНО: посмотрите/сохраните пароль "
"ДО удаления — после стирания его не восстановить. Сам роутер не "
"сбрасывается."
msgstr ""
"删除后，下次登录将需要路由器的 root "
"密码。你是有这个密码的——它在设置时显示过，也可以在设备的「安全」一节中查看。重要：请在删除之前查看／保存好密码——抹除后将无法恢复。路由器本身不会被重置。"

#: src/re_sputnik/ui/advanced_screen.py:1111
#: src/re_sputnik/ui/connect_screen.py:322
msgid "Данные приложения удалены с этого компьютера. Перезапустите Re:Sputnik."
msgstr "应用数据已从本台计算机删除。请重新启动 Re:Sputnik。"

#: src/re_sputnik/ui/advanced_screen.py:1116
#: src/re_sputnik/ui/connect_screen.py:329
#, python-brace-format
msgid "Не удалось полностью удалить: {0}"
msgstr "未能完全删除：{0}"

#: src/re_sputnik/ui/antidpi_screen.py:26
msgid "отказ"
msgstr "拒绝"

#: src/re_sputnik/ui/antidpi_screen.py:26
msgid "таймаут"
msgstr "超时"

#: src/re_sputnik/ui/antidpi_screen.py:27
msgid "сбой"
msgstr "失败"

#: src/re_sputnik/ui/antidpi_screen.py:47
msgid ""
"Обход DPI для сервисов, где не нужен полный VPN. Два инструмента — "
"попробуйте оба, что сработает, зависит от провайдера."
msgstr "针对不需要完整 VPN 的服务进行 DPI 绕过。提供两种工具——都试试，哪个有效取决于运营商。"

#: src/re_sputnik/ui/antidpi_screen.py:70
msgid "Считываю ByeDPI…"
msgstr "正在读取 ByeDPI…"

#: src/re_sputnik/ui/antidpi_screen.py:109
#: src/re_sputnik/ui/antidpi_screen.py:304
msgid "🟢 установлен и запущен"
msgstr "🟢 已安装并运行"

#: src/re_sputnik/ui/antidpi_screen.py:110
#: src/re_sputnik/ui/antidpi_screen.py:305
msgid "🟡 установлен, остановлен"
msgstr "🟡 已安装，已停止"

#: src/re_sputnik/ui/antidpi_screen.py:110
#: src/re_sputnik/ui/antidpi_screen.py:305 src/re_sputnik/ui/core_screen.py:489
