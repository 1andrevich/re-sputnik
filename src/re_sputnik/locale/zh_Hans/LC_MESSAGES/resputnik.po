msgstr "▶ 运行测试"

#: src/re_sputnik/ui/antidpi_screen.py:168
#: src/re_sputnik/ui/antidpi_screen.py:471
msgid "Стратегия подставлена — нажмите «Сохранить»."
msgstr "策略已填入——请点击“保存”。"

#: src/re_sputnik/ui/antidpi_screen.py:176
#: src/re_sputnik/ui/antidpi_screen.py:493
