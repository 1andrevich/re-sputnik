msgid "Шифрование"
msgstr "加密方式"

#: src/re_sputnik/ui/advanced_screen.py:459
msgid "Канал"
msgstr "信道"

#: src/re_sputnik/ui/advanced_screen.py:473
#, python-brace-format
msgid "{0} МГц"
msgstr "{0} MHz"

#: src/re_sputnik/ui/advanced_screen.py:475
