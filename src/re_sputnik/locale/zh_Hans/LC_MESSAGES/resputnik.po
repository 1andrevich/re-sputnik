#: src/re_sputnik/ui/software_screen.py:179
msgid "Устанавливаю…"
msgstr "正在安装…"

#: src/re_sputnik/engine/byedpi.py:166
msgid "Установка ByeDPI не удалась."
msgstr "ByeDPI 安装失败。"

#: src/re_sputnik/engine/byedpi.py:167
msgid "ByeDPI установлен."
msgstr "ByeDPI 已安装。"

#: src/re_sputnik/engine/core_health.py:36
msgid "сервер использует Reality, но в ссылке нет uTLS-отпечатка"
msgstr "服务器使用 Reality，但链接中没有 uTLS 指纹"

#: src/re_sputnik/engine/core_health.py:37
msgid "у сервера не настроен TLS"
msgstr "服务器未配置 TLS"

#: src/re_sputnik/engine/core_health.py:38
msgid "неподдерживаемый метод шифрования"
msgstr "不支持的加密方式"

#: src/re_sputnik/engine/core_health.py:39
msgid "неподдерживаемый шифр"
msgstr "不支持的加密算法"

#: src/re_sputnik/engine/core_health.py:40
msgid "неверный UUID в ссылке"
msgstr "链接中的 UUID 无效"

#: src/re_sputnik/engine/core_health.py:41
msgid "не удалось разобрать параметры сервера"
msgstr "无法解析服务器参数"

#: src/re_sputnik/engine/core_health.py:137
#, python-brace-format
msgid ""
"Ядро не запускается из-за сервера «{0}»: {1}. Это не поломка ядра — оно "
"не может загрузить конфигурацию из-за одного сервера."
msgstr "内核因服务器“{0}”无法启动：{1}。这不是内核故障——它只是因为一个服务器而无法加载配置。"

#: src/re_sputnik/engine/core_health.py:141
#, python-brace-format
msgid ""
"Уберите сервер «{0}» из пула URLTest (или выберите другой основной "
"сервер)."
msgstr "从 URLTest 池中移除服务器“{0}”（或选择另一个主服务器）。"

#: src/re_sputnik/engine/core_health.py:142
msgid "Перезапустите сервис — ядро запустится с остальными серверами."
msgstr "重启服务——内核将使用剩余的服务器启动。"

#: src/re_sputnik/engine/core_health.py:145
#, python-brace-format
msgid "Ядро не запускается из-за ошибки в конфигурации: {0}. Это не поломка ядра."
msgstr "内核因配置错误无法启动：{0}。这不是内核故障。"

#: src/re_sputnik/engine/core_health.py:148
msgid ""
"Уберите недавно добавленный / проблемный сервер из пула или выберите "
"другой основной."
msgstr "从池中移除最近添加的/有问题的服务器，或选择另一个主服务器。"

#: src/re_sputnik/engine/core_health.py:149
msgid "Перезапустите сервис."
msgstr "重启服务。"

#: src/re_sputnik/engine/core_health.py:152
msgid "Ядро не запускается из-за ошибки в конфигурации (это не поломка ядра)."
msgstr "内核因配置错误无法启动（这不是内核故障）。"

#: src/re_sputnik/engine/core_health.py:153
msgid ""
"Проверьте список серверов и выберите другой основной сервер, затем "
"перезапустите."
msgstr "检查服务器列表，选择另一个主服务器，然后重启。"

#: src/re_sputnik/engine/finalize.py:97
msgid "UPnP / NAT-PMP — автопроброс портов"
msgstr "UPnP / NAT-PMP — 自动端口转发"

#: src/re_sputnik/engine/finalize.py:98
msgid ""
"Позволяет приставкам, играм, торрент-клиентам и видеозвонкам самим "
"открывать нужные порты — без ручной настройки проброса. Удобно, но любое "
"приложение в сети сможет открыть порт наружу, поэтому включайте, если это"
" действительно нужно."
msgstr ""
"允许游戏机、游戏、torrent "
"客户端和视频通话自行打开所需端口——无需手动配置端口转发。方便，但网络上的任何应用都能向外打开端口，因此仅在确实需要时启用。"

#: src/re_sputnik/engine/finalize.py:101
msgid "SQM — умная очередь (борьба с лагами)"
msgstr "SQM — 智能队列（减少卡顿）"

#: src/re_sputnik/engine/finalize.py:102
msgid ""
"Не даёт каналу «захлёбываться», когда кто-то качает или раздаёт большой "
"трафик: пинг остаётся низким. Заметно улучшает игры и видеозвонки во "
"время загрузок (устраняет буфер-блоат)."
msgstr "当有人下载或上传大量流量时，防止网络“拥堵”：延迟保持较低。在下载时明显改善游戏和视频通话体验（消除缓冲膨胀）。"

#: src/re_sputnik/engine/firmware.py:76
msgid "Прошивка без поддержки nftables"
msgstr "不支持 nftables 的固件"

#: src/re_sputnik/engine/firmware.py:77
msgid ""
"В прошивке нет nftables (команды nft). HomeProxy использует nft-tproxy и "
"не сможет работать на этой сборке (например, некоторые кастомные сборки "
"собраны без firewall4/nftables)."
msgstr ""
"固件中没有 nftables（nft 命令）。HomeProxy 使用 nft-tproxy，无法在此固件上运行（例如某些自定义固件未编译 "
"firewall4/nftables）。"

#: src/re_sputnik/engine/firmware.py:80
msgid "Нужна прошивка OpenWrt с firewall4 (nftables)."
msgstr "需要带 firewall4（nftables）的 OpenWrt 固件。"

#: src/re_sputnik/engine/firmware.py:86
msgid "nftables не отвечает"
msgstr "nftables 无响应"

#: src/re_sputnik/engine/firmware.py:87
msgid ""
"Команда nft есть, но «nft list ruleset» завершилась с ошибкой — возможно,"
" активен firewall на iptables, а не firewall4."
msgstr "存在 nft 命令，但“nft list ruleset”执行出错——可能正在使用 iptables 防火墙，而不是 firewall4。"

#: src/re_sputnik/engine/firmware.py:89
msgid "Убедитесь, что используется firewall4 (nftables)."
msgstr "请确认正在使用 firewall4（nftables）。"

#: src/re_sputnik/engine/firmware.py:97
msgid "Похоже, firewall не на nftables"
msgstr "防火墙似乎不是 nftables"

#: src/re_sputnik/engine/firmware.py:98
msgid ""
"nftables есть, но firewall4 (fw4) не найден — возможно, прошивка "
"использует firewall на iptables. HomeProxy рассчитан на firewall4 и nft-"
"tproxy."
msgstr ""
"存在 nftables，但未找到 firewall4（fw4）——固件可能使用 iptables 防火墙。HomeProxy 依赖 "
"firewall4 和 nft-tproxy。"

#: src/re_sputnik/engine/firmware.py:100
msgid "Используйте прошивку OpenWrt с firewall4 (nftables)."
msgstr "请使用带 firewall4（nftables）的 OpenWrt 固件。"

#: src/re_sputnik/engine/firmware.py:111
msgid "FriendlyWrt: br-netfilter ломает nft-tproxy"
msgstr "FriendlyWrt：br-netfilter 会破坏 nft-tproxy"

#: src/re_sputnik/engine/firmware.py:112
msgid ""
"Модуль br_netfilter направляет трафик моста через iptables, из-за чего "
"nft-tproxy не перехватывает соединения и прокси не работает."
msgstr "br_netfilter 模块会将桥接流量导向 iptables，导致 nft-tproxy 无法拦截连接，代理因此无法工作。"

#: src/re_sputnik/engine/firmware.py:114
msgid ""
"Отключите bridge-nf-call-iptables (sysctl) или выгрузите модуль "
"br_netfilter."
msgstr "请关闭 bridge-nf-call-iptables（sysctl）或卸载 br_netfilter 模块。"

#: src/re_sputnik/engine/firmware.py:128
msgid "GL.iNet: конфликт правил маркировки трафика"
msgstr "GL.iNet：流量标记规则冲突"

#: src/re_sputnik/engine/firmware.py:129
msgid ""
"Встроенная служба vpn-client GL.iNet создаёт собственные правила "
"маркировки в nftables, из-за чего трафик не доходит до sing-box"
msgstr "GL.iNet 内置的 vpn-client 服务会在 nftables 中创建自己的标记规则，导致流量无法到达 sing-box"

#: src/re_sputnik/engine/firmware.py:131
msgid " (служба vpn-client сейчас включена)."
msgstr "（vpn-client 服务当前已启用）。"

#: src/re_sputnik/engine/firmware.py:132
msgid "Отключите GL.iNet VPN (vpn-client) перед использованием HomeProxy."
msgstr "请在使用 HomeProxy 前关闭 GL.iNet VPN（vpn-client）。"

#: src/re_sputnik/engine/firmware.py:145
msgid "перехват трафика (nft-tproxy)"
msgstr "流量拦截（nft-tproxy）"

#: src/re_sputnik/engine/firmware.py:146
msgid "режим TUN"
msgstr "TUN 模式"

#: src/re_sputnik/engine/firmware.py:198
#, python-brace-format
msgid "{0}: пакет {1} недоступен для ядра этой прошивки — прошивка несовместима"
msgstr "{0}：此固件内核不支持软件包 {1}——固件不兼容"

#: src/re_sputnik/engine/firmware.py:200
#, python-brace-format
msgid "{0}: пакет {1} не установился"
msgstr "{0}：软件包 {1} 安装失败"

#: src/re_sputnik/engine/firstrun.py:80
msgid "пароль не сохранился на роутере (passwd не применил его)"
msgstr "密码未保存到路由器（passwd 未生效）"

#: src/re_sputnik/engine/firstrun.py:108
msgid "Устанавливаю SSH-ключ приложения…"
msgstr "正在安装应用的 SSH 密钥…"

#: src/re_sputnik/engine/firstrun.py:116
msgid "Проверяю вход по ключу…"
msgstr "正在检查密钥登录…"

#: src/re_sputnik/engine/firstrun.py:118
msgid "ключ установлен, но вход по нему не подтвердился — пароль не меняю"
msgstr "密钥已安装，但无法确认能否用它登录——不更改密码"

#: src/re_sputnik/engine/firstrun.py:121
msgid "Вход по ключу работает."
msgstr "密钥登录可用。"

#: src/re_sputnik/engine/firstrun.py:128
msgid ""
"Постоянный ключ не устанавливается (по выбору). Для будущих подключений "
"потребуется пароль."
msgstr "不安装永久密钥（按您的选择）。今后的连接将需要密码。"

#: src/re_sputnik/engine/firstrun.py:135
msgid "У роутера уже задан пароль — оставляю без изменений."
msgstr "路由器已设置密码——保持不变。"

#: src/re_sputnik/engine/firstrun.py:138
msgid "Устанавливаю root-пароль…"
msgstr "正在设置 root 密码…"

#: src/re_sputnik/engine/firstrun.py:150
msgid "Пароль сохранён в хранилище Windows."
msgstr "密码已保存到 Windows 凭据管理器。"

#: src/re_sputnik/engine/firstrun.py:155
msgid "Первичная настройка завершена."
msgstr "初始设置完成。"

#: src/re_sputnik/engine/install_app.py:328
#: src/re_sputnik/engine/install_app.py:332
msgid "обновление репозитория"
msgstr "刷新软件源"

#: src/re_sputnik/engine/install_app.py:418
msgid ""
"На устройстве SNAPSHOT-сборка OpenWrt — kmod из релизного репозитория "
"недоступны. Используйте релизную прошивку."
msgstr "设备上是 OpenWrt SNAPSHOT 构建——发行版仓库中的 kmod 不可用。请使用发行版固件。"

#: src/re_sputnik/engine/install_app.py:428
msgid "Устанавливаю приложение Re:HomeProxy…"
msgstr "正在安装 Re:HomeProxy 应用…"

#: src/re_sputnik/engine/install_app.py:439
msgid "не удалось скачать пакет приложения на роутер"
msgstr "无法将应用软件包下载到路由器"

#: src/re_sputnik/engine/install_app.py:459
msgid "Приложение установлено"
msgstr "应用已安装"

#: src/re_sputnik/engine/install_app.py:478
#: src/re_sputnik/engine/install_app.py:699
#: src/re_sputnik/engine/preinstall.py:448
msgid "Перезапускаю rpcd…"
msgstr "正在重启 rpcd…"

#: src/re_sputnik/engine/install_app.py:489
#: src/re_sputnik/engine/install_app.py:596
msgid "Скачиваю ядро на роутер…"
