msgstr "   ⚠ 缺少 NFQUEUE 模块（kmod-nft-queue）"

#: src/re_sputnik/ui/antidpi_screen.py:326
msgid "Включить Zapret"
msgstr "启用 Zapret"

#: src/re_sputnik/ui/antidpi_screen.py:340
msgid "Стратегия (опции nfqws2):"
msgstr "策略（nfqws2 选项）："

#: src/re_sputnik/ui/antidpi_screen.py:347
msgid "Звонки Discord через Zapret"
msgstr "通过 Zapret 进行 Discord 通话"

#: src/re_sputnik/ui/antidpi_screen.py:363
msgid "Тест стратегий"
msgstr "测试策略"

#: src/re_sputnik/ui/antidpi_screen.py:365
msgid ""
"● = TLS-рукопожатие успешно, ○ = заблокировано. Ваше соединение во время "
"теста не затрагивается."
msgstr "● = TLS 握手成功，○ = 已被阻止。测试期间不会影响您的连接。"

#: src/re_sputnik/ui/antidpi_screen.py:372
#: src/re_sputnik/ui/antidpi_screen.py:539
#: src/re_sputnik/ui/antidpi_screen.py:544
msgid "▶ Тест текущей"
msgstr "▶ 测试当前策略"

#: src/re_sputnik/ui/antidpi_screen.py:376
msgid "⚡ Полная проверка"
msgstr "⚡ 全面检查"

#: src/re_sputnik/ui/antidpi_screen.py:379
msgid "■ Стоп"
msgstr "■ 停止"

#: src/re_sputnik/ui/antidpi_screen.py:406
msgid "Менеджер пакетов не найден — установите zapret2 вручную."
msgstr "未找到包管理器——请手动安装 zapret2。"

#: src/re_sputnik/ui/antidpi_screen.py:409
msgid "Zapret (zapret2/nfqws2) не установлен. Установить сейчас?"
msgstr "Zapret（zapret2/nfqws2）未安装。现在安装吗？"

#: src/re_sputnik/ui/antidpi_screen.py:412
#: src/re_sputnik/ui/antidpi_screen.py:435
#: src/re_sputnik/ui/antidpi_screen.py:441
msgid "Установить Zapret"
msgstr "安装 Zapret"

#: src/re_sputnik/ui/antidpi_screen.py:479
msgid "Сначала установите Zapret (кнопка выше)."
msgstr "请先安装 Zapret（上方按钮）。"

#: src/re_sputnik/ui/antidpi_screen.py:486
msgid ""
"Нет модуля ядра NFQUEUE (kmod-nft-queue). Переустановите Zapret на "
"странице «Ядро» или установите kmod-nft-queue — иначе включение сломает "
"firewall."
msgstr ""
"缺少 NFQUEUE 内核模块（kmod-nft-queue）。请在“内核”页面重新安装 Zapret，或安装 kmod-nft-"
"queue——否则启用它会破坏防火墙。"

#: src/re_sputnik/ui/antidpi_screen.py:531
msgid "Сначала выберите или введите стратегию."
msgstr "请先选择或输入策略。"

#: src/re_sputnik/ui/antidpi_screen.py:533
msgid "Тестирую…"
msgstr "正在测试…"

#: src/re_sputnik/ui/antidpi_screen.py:568
msgid "Список стратегий недоступен."
msgstr "策略列表不可用。"

#: src/re_sputnik/ui/antidpi_screen.py:589
