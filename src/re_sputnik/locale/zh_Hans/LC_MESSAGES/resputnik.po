#: src/re_sputnik/app.py:467
msgid "Закрыть"
msgstr "关闭"

#: src/re_sputnik/app.py:382
msgid "Принимаю и продолжаю"
msgstr "接受并继续"

#: src/re_sputnik/app.py:387
msgid "Я понимаю и принимаю условия использования"
msgstr "我理解并接受这些使用条款"

#: src/re_sputnik/app.py:393
msgid "Назад"
msgstr "返回"

#: src/re_sputnik/app.py:446
