msgstr "🔴 未安装"

#: src/re_sputnik/ui/antidpi_screen.py:114
#: src/re_sputnik/ui/antidpi_screen.py:311
msgid "Версия"
msgstr "版本"

#: src/re_sputnik/ui/antidpi_screen.py:114
#: src/re_sputnik/ui/antidpi_screen.py:311 src/re_sputnik/ui/core_screen.py:296
