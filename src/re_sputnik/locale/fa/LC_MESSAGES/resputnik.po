msgstr "تغییر یافت — «اعمال تغییرات» را کلیک کنید."

#: src/re_sputnik/ui/antidpi_screen.py:184
#: src/re_sputnik/ui/antidpi_screen.py:509
msgid "Сохранено — нажмите «Применить изменения»."
msgstr "ذخیره شد — «اعمال تغییرات» را کلیک کنید."

#: src/re_sputnik/ui/antidpi_screen.py:194
#: src/re_sputnik/ui/antidpi_screen.py:519
