msgstr "تست استراتژی"

#: src/re_sputnik/ui/antidpi_screen.py:153
msgid "● = TLS-рукопожатие успешно, ○ = заблокировано"
msgstr "● = دست‌دهی TLS موفق، ○ = مسدود شده"

#: src/re_sputnik/ui/antidpi_screen.py:155
#: src/re_sputnik/ui/antidpi_screen.py:210
