#: src/re_sputnik/app.py:39
msgid ""
"⚠️ Важно, прочитайте перед началом.\n"
"\n"
"Настройку выполняет программа Re:Sputnik, которая может содержать ошибки."
" Всё программное обеспечение и конфигурации предоставляются «как есть», "
"без каких-либо гарантий. Авторы Re:Sputnik, Re:HomeProxy и всего "
"предоставляемого ПО не несут ответственности за любой возможный ущерб, "
"потерю данных, проблемы со связью, блокировки или иные последствия.\n"
"\n"
"Вы действуете на свой страх и риск и сами отвечаете за соблюдение законов"
" вашей страны в отношении использования VPN/прокси.\n"
"\n"
"Продолжая, вы принимаете эти условия."
msgstr ""
"⚠️ مهم، لطفاً پیش از شروع بخوانید.\n"
"\n"
"Re:Sputnik برنامه‌ای است که ممکن است دارای اشکال باشد. تمام نرم‌افزارها و"
" تنظیمات «همان‌گونه که هست» ارائه می‌شوند، بدون هیچ ضمانتی. نویسندگان "
"Re:Sputnik، Re:HomeProxy و تمام نرم‌افزارهای ارائه‌شده هیچ مسئولیتی در "
"برابر خسارت احتمالی، از دست رفتن داده‌ها، مشکلات ارتباطی، مسدودسازی‌ها یا"
" سایر پیامدها ندارند.\n"
"\n"
"شما با مسئولیت خود اقدام می‌کنید و خود مسئول رعایت قوانین کشور خود در "
"مورد استفاده از VPN/پروکسی هستید.\n"
"\n"
"با ادامه دادن، این شرایط را می‌پذیرید."

#: src/re_sputnik/app.py:286 src/re_sputnik/app.py:365
msgid "Лицензионное соглашение"
msgstr "توافق‌نامه مجوز"

#: src/re_sputnik/app.py:288
msgid "Пожалуйста, прочитайте лицензионное соглашение."
msgstr "لطفاً توافق‌نامه مجوز را بخوانید."

#: src/re_sputnik/app.py:300 src/re_sputnik/ui/verify_screen.py:105
msgid "Далее"
msgstr "بعدی"

#: src/re_sputnik/app.py:305
msgid "Я прочитал(а) и принимаю условия Лицензионного соглашения"
msgstr "متن توافق‌نامه مجوز را خوانده‌ام و شرایط آن را می‌پذیرم"

#: src/re_sputnik/app.py:309
msgid "Выход"
msgstr "خروج"

#: src/re_sputnik/app.py:339
msgid "Перед началом"
msgstr "پیش از شروع"

#: src/re_sputnik/app.py:354
msgid ""
"Re:Sputnik — закрытое бесплатное ПО. Сторонние проекты, которые оно "
"использует, и их лицензии перечислены в уведомлении о компонентах."
msgstr ""
"Re:Sputnik نرم‌افزار رایگان با کد منبع بسته است. پروژه‌های شخص ثالثی که "
"استفاده می‌کند و مجوزهای آن‌ها در اعلان اجزاء فهرست شده‌اند."

#: src/re_sputnik/app.py:362
msgid "Полный текст соглашения"
msgstr "متن کامل توافق‌نامه"

#: src/re_sputnik/app.py:368 src/re_sputnik/app.py:437
msgid "Сторонние компоненты и лицензии"
msgstr "اجزای شخص ثالث و مجوزها"

#: src/re_sputnik/app.py:376 src/re_sputnik/app.py:414
#: src/re_sputnik/app.py:467
msgid "Закрыть"
msgstr "بستن"

#: src/re_sputnik/app.py:382
msgid "Принимаю и продолжаю"
msgstr "می‌پذیرم و ادامه می‌دهم"

#: src/re_sputnik/app.py:387
msgid "Я понимаю и принимаю условия использования"
msgstr "این شرایط استفاده را می‌فهمم و می‌پذیرم"

#: src/re_sputnik/app.py:393
msgid "Назад"
msgstr "بازگشت"

#: src/re_sputnik/app.py:446
msgid "Документы"
msgstr "اسناد"

#: src/re_sputnik/app.py:523
msgid "Настройка Re:HomeProxy на роутере OpenWRT"
msgstr "راه‌اندازی Re:HomeProxy روی روتر OpenWRT"

#: src/re_sputnik/app.py:535
msgid "Пошаговая настройка"
msgstr "راه‌اندازی گام‌به‌گام"

#: src/re_sputnik/app.py:536
msgid "Приложение ведёт за руку: интернет, установка, серверы, проверка"
msgstr "برنامه شما را راهنمایی می‌کند: اینترنت، نصب، سرورها، بررسی"

#: src/re_sputnik/app.py:544
msgid "Расширенный"
msgstr "پیشرفته"

#: src/re_sputnik/app.py:545
msgid "Свободная навигация по разделам: Серверы, Правила, Диагностика…"
msgstr "پیمایش آزاد بین بخش‌ها: سرورها، قوانین، عیب‌یابی…"

#: src/re_sputnik/app.py:553 src/re_sputnik/ui/preinstall_screen.py:47
msgid "Предустановить пакеты"
msgstr "پیش‌نصب بسته‌ها"

#: src/re_sputnik/app.py:554
msgid "Скачать на ПК и залить на роутер для установки без интернета"
msgstr "دانلود روی رایانه و انتقال به روتر برای نصب بدون اینترنت"

#: src/re_sputnik/app.py:560
msgid ""
"Роутер уже настроен? Любой режим подхватит текущую конфигурацию, а не "
"начнёт с нуля."
msgstr ""
"روتر از قبل تنظیم شده؟ هر حالتی تنظیمات فعلی را ادامه می‌دهد، نه شروع از "
"صفر."

#: src/re_sputnik/app.py:568
msgid "Дисклеймер"
msgstr "اعلان رفع مسئولیت"

#: src/re_sputnik/app.py:577
msgid "Перевод на этот язык машинный — будем рады исправлениям."
msgstr "ترجمه این زبان ماشینی است — اصلاحات شما خوش‌آیند است."

#: src/re_sputnik/secrets.py:42
msgid "пробел"
msgstr "فاصله"

#: src/re_sputnik/secrets.py:42
msgid "табуляция"
msgstr "تب"

#: src/re_sputnik/secrets.py:59
msgid ""
"Пароль содержит символы не из английской раскладки. Переключитесь на "
"английскую раскладку и используйте латинские буквы, цифры и спецзнаки."
msgstr ""
"گذرواژه شامل نویسه‌هایی است که از چیدمان صفحه‌کلید انگلیسی نیستند. به "
"چیدمان انگلیسی بروید و از حروف لاتین، اعداد و نویسه‌های ویژه استفاده "
"کنید."

#: src/re_sputnik/secrets.py:63
msgid "Эти символы несовместимы и не разрешены в пароле: "
msgstr "این نویسه‌ها ناسازگارند و در گذرواژه مجاز نیستند: "

#: src/re_sputnik/secrets.py:64
msgid ""
" Уберите их (можно использовать другие спецзнаки: ! @ # % ^ & * - _ = + и"
" т.п.)."
msgstr ""
" آن‌ها را حذف کنید (می‌توانید از نویسه‌های ویژه دیگر استفاده کنید: ! @ # "
"% ^ & * - _ = + و غیره)."

#: src/re_sputnik/engine/byedpi.py:147 src/re_sputnik/engine/zapret.py:120
msgid "Проверяю требования…"
msgstr "در حال بررسی پیش‌نیازها…"

#: src/re_sputnik/engine/byedpi.py:150 src/re_sputnik/engine/zapret.py:123
msgid "Не удалось подготовить установку (нет ссылки)."
msgstr "آماده‌سازی نصب ممکن نشد (لینکی موجود نیست)."

#: src/re_sputnik/engine/byedpi.py:153
msgid "Устанавливаю curl (нужен тестеру)…"
msgstr "در حال نصب curl (برای ابزار تست لازم است)…"

#: src/re_sputnik/engine/byedpi.py:157 src/re_sputnik/engine/zapret.py:125
msgid "Скачиваю пакет…"
msgstr "در حال دانلود بسته…"

#: src/re_sputnik/engine/byedpi.py:159
msgid "Не удалось скачать пакет ByeDPI."
msgstr "دانلود بسته ByeDPI ناموفق بود."

#: src/re_sputnik/engine/byedpi.py:161 src/re_sputnik/engine/zapret.py:129
#: src/re_sputnik/ui/antidpi_screen.py:421
#: src/re_sputnik/ui/finalize_screen.py:211
#: src/re_sputnik/ui/finalize_screen.py:270
#: src/re_sputnik/ui/security_screen.py:344
#: src/re_sputnik/ui/software_screen.py:179
msgid "Устанавливаю…"
msgstr "در حال نصب…"

#: src/re_sputnik/engine/byedpi.py:166
msgid "Установка ByeDPI не удалась."
msgstr "نصب ByeDPI ناموفق بود."

#: src/re_sputnik/engine/byedpi.py:167
msgid "ByeDPI установлен."
msgstr "ByeDPI نصب شد."

#: src/re_sputnik/engine/core_health.py:36
msgid "сервер использует Reality, но в ссылке нет uTLS-отпечатка"
msgstr "سرور از Reality استفاده می‌کند، اما لینک اثر انگشت uTLS ندارد"

#: src/re_sputnik/engine/core_health.py:37
msgid "у сервера не настроен TLS"
msgstr "سرور TLS تنظیم‌شده ندارد"

#: src/re_sputnik/engine/core_health.py:38
msgid "неподдерживаемый метод шифрования"
msgstr "روش رمزنگاری پشتیبانی نمی‌شود"

#: src/re_sputnik/engine/core_health.py:39
msgid "неподдерживаемый шифр"
msgstr "الگوریتم رمزنگاری پشتیبانی نمی‌شود"

#: src/re_sputnik/engine/core_health.py:40
msgid "неверный UUID в ссылке"
msgstr "UUID نامعتبر در لینک"

#: src/re_sputnik/engine/core_health.py:41
msgid "не удалось разобрать параметры сервера"
msgstr "تجزیهٔ پارامترهای سرور ممکن نشد"

#: src/re_sputnik/engine/core_health.py:137
#, python-brace-format
msgid ""
"Ядро не запускается из-за сервера «{0}»: {1}. Это не поломка ядра — оно "
"не может загрузить конфигурацию из-за одного сервера."
msgstr ""
"هسته به دلیل سرور «{0}» اجرا نمی‌شود: {1}. این خرابی هسته نیست — هسته فقط"
" به دلیل یک سرور نمی‌تواند تنظیمات را بار کند."

#: src/re_sputnik/engine/core_health.py:141
#, python-brace-format
msgid ""
"Уберите сервер «{0}» из пула URLTest (или выберите другой основной "
"сервер)."
msgstr ""
"سرور «{0}» را از مجموعهٔ URLTest حذف کنید (یا سرور اصلی دیگری انتخاب "
"کنید)."

#: src/re_sputnik/engine/core_health.py:142
msgid "Перезапустите сервис — ядро запустится с остальными серверами."
msgstr ""
"سرویس را مجدداً راه‌اندازی کنید — هسته با سرورهای باقی‌مانده اجرا خواهد "
"شد."

#: src/re_sputnik/engine/core_health.py:145
#, python-brace-format
msgid "Ядро не запускается из-за ошибки в конфигурации: {0}. Это не поломка ядра."
msgstr "هسته به دلیل خطای تنظیمات اجرا نمی‌شود: {0}. این خرابی هسته نیست."

#: src/re_sputnik/engine/core_health.py:148
msgid ""
"Уберите недавно добавленный / проблемный сервер из пула или выберите "
"другой основной."
msgstr ""
"سرور تازه‌اضافه‌شده/مشکل‌دار را از مجموعه حذف کنید یا سرور اصلی دیگری "
"انتخاب کنید."

#: src/re_sputnik/engine/core_health.py:149
msgid "Перезапустите сервис."
msgstr "سرویس را مجدداً راه‌اندازی کنید."

#: src/re_sputnik/engine/core_health.py:152
msgid "Ядро не запускается из-за ошибки в конфигурации (это не поломка ядра)."
msgstr "هسته به دلیل خطای تنظیمات اجرا نمی‌شود (این خرابی هسته نیست)."

#: src/re_sputnik/engine/core_health.py:153
msgid ""
"Проверьте список серверов и выберите другой основной сервер, затем "
"перезапустите."
msgstr ""
"فهرست سرورها را بررسی کنید، سرور اصلی دیگری انتخاب کنید، سپس مجدداً "
"راه‌اندازی کنید."

#: src/re_sputnik/engine/finalize.py:97
msgid "UPnP / NAT-PMP — автопроброс портов"
msgstr "UPnP / NAT-PMP — انتقال خودکار پورت"

#: src/re_sputnik/engine/finalize.py:98
msgid ""
"Позволяет приставкам, играм, торрент-клиентам и видеозвонкам самим "
"открывать нужные порты — без ручной настройки проброса. Удобно, но любое "
"приложение в сети сможет открыть порт наружу, поэтому включайте, если это"
" действительно нужно."
msgstr ""
"به کنسول‌ها، بازی‌ها، کلاینت‌های تورنت و تماس‌های تصویری اجازه می‌دهد "
"خودشان پورت‌های لازم را باز کنند — بدون تنظیم دستی انتقال پورت. راحت است،"
" اما هر برنامه‌ای در شبکه می‌تواند پورتی را به بیرون باز کند، پس فقط در "
"صورت نیاز واقعی فعال کنید."

#: src/re_sputnik/engine/finalize.py:101
msgid "SQM — умная очередь (борьба с лагами)"
msgstr "SQM — صف هوشمند (کاهش تأخیر)"

#: src/re_sputnik/engine/finalize.py:102
msgid ""
"Не даёт каналу «захлёбываться», когда кто-то качает или раздаёт большой "
"трафик: пинг остаётся низким. Заметно улучшает игры и видеозвонки во "
"время загрузок (устраняет буфер-блоат)."
msgstr ""
"وقتی کسی حجم زیادی دانلود یا آپلود می‌کند، از «گرفتگی» اینترنت جلوگیری "
"می‌کند: تأخیر پایین می‌ماند. تماس‌های تصویری و بازی‌ها در زمان دانلود "
"به‌وضوح بهتر می‌شوند (رفع bufferbloat)."

#: src/re_sputnik/engine/firmware.py:76
msgid "Прошивка без поддержки nftables"
msgstr "فرم‌ور بدون پشتیبانی nftables"

#: src/re_sputnik/engine/firmware.py:77
msgid ""
"В прошивке нет nftables (команды nft). HomeProxy использует nft-tproxy и "
"не сможет работать на этой сборке (например, некоторые кастомные сборки "
"собраны без firewall4/nftables)."
msgstr ""
"در این فرم‌ور nftables (دستورات nft) وجود ندارد. HomeProxy از nft-tproxy "
"استفاده می‌کند و روی این ساخت کار نخواهد کرد (مثلاً برخی ساخت‌های سفارشی "
"بدون firewall4/nftables ساخته شده‌اند)."

#: src/re_sputnik/engine/firmware.py:80
msgid "Нужна прошивка OpenWrt с firewall4 (nftables)."
msgstr "فرم‌ور OpenWrt با firewall4 (nftables) لازم است."

#, python-brace-format
msgid ""
"На роутере OpenWrt {0} — нужна версия 23.05 или новее. Обновите прошивку "
"роутера."
msgstr ""
"روتر OpenWrt {0} را اجرا می‌کند — نسخهٔ 23.05 یا جدیدتر لازم است. فرم‌ور "
"روتر را به‌روزرسانی کنید."

#: src/re_sputnik/engine/firmware.py:86
msgid "nftables не отвечает"
msgstr "nftables پاسخ نمی‌دهد"

#: src/re_sputnik/engine/firmware.py:87
msgid ""
"Команда nft есть, но «nft list ruleset» завершилась с ошибкой — возможно,"
" активен firewall на iptables, а не firewall4."
msgstr ""
"دستور nft وجود دارد، اما «nft list ruleset» با خطا مواجه شد — احتمالاً "
"دیوار آتش روی iptables فعال است، نه firewall4."

#: src/re_sputnik/engine/firmware.py:89
msgid "Убедитесь, что используется firewall4 (nftables)."
msgstr "مطمئن شوید از firewall4 (nftables) استفاده می‌شود."

#: src/re_sputnik/engine/firmware.py:97
msgid "Похоже, firewall не на nftables"
msgstr "به نظر می‌رسد دیوار آتش از nftables استفاده نمی‌کند"

#: src/re_sputnik/engine/firmware.py:98
msgid ""
"nftables есть, но firewall4 (fw4) не найден — возможно, прошивка "
"использует firewall на iptables. HomeProxy рассчитан на firewall4 и nft-"
"tproxy."
msgstr ""
"nftables وجود دارد، اما firewall4 (fw4) یافت نشد — ممکن است فرم‌ور از "
"دیوار آتش iptables استفاده کند. HomeProxy به firewall4 و nft-tproxy نیاز "
"دارد."

#: src/re_sputnik/engine/firmware.py:100
msgid "Используйте прошивку OpenWrt с firewall4 (nftables)."
msgstr "از فرم‌ور OpenWrt با firewall4 (nftables) استفاده کنید."

#: src/re_sputnik/engine/firmware.py:111
msgid "FriendlyWrt: br-netfilter ломает nft-tproxy"
msgstr "FriendlyWrt: br-netfilter باعث خرابی nft-tproxy می‌شود"

#: src/re_sputnik/engine/firmware.py:112
msgid ""
"Модуль br_netfilter направляет трафик моста через iptables, из-за чего "
"nft-tproxy не перехватывает соединения и прокси не работает."
msgstr ""
"ماژول br_netfilter ترافیک پل را از طریق iptables هدایت می‌کند، که موجب "
"می‌شود nft-tproxy اتصالات را رهگیری نکند و پروکسی کار نکند."

#: src/re_sputnik/engine/firmware.py:114
msgid ""
"Отключите bridge-nf-call-iptables (sysctl) или выгрузите модуль "
"br_netfilter."
msgstr ""
"bridge-nf-call-iptables (sysctl) را غیرفعال کنید یا ماژول br_netfilter را"
" خارج کنید."

#: src/re_sputnik/engine/firmware.py:128
msgid "GL.iNet: конфликт правил маркировки трафика"
msgstr "GL.iNet: تضاد قوانین نشانه‌گذاری ترافیک"

#: src/re_sputnik/engine/firmware.py:129
msgid ""
"Встроенная служба vpn-client GL.iNet создаёт собственные правила "
"маркировки в nftables, из-за чего трафик не доходит до sing-box"
msgstr ""
"سرویس داخلی vpn-client در GL.iNet قوانین نشانه‌گذاری خود را در nftables "
"ایجاد می‌کند که باعث می‌شود ترافیک به sing-box نرسد"

#: src/re_sputnik/engine/firmware.py:131
msgid " (служба vpn-client сейчас включена)."
msgstr " (سرویس vpn-client اکنون فعال است)."

#: src/re_sputnik/engine/firmware.py:132
msgid "Отключите GL.iNet VPN (vpn-client) перед использованием HomeProxy."
msgstr ""
